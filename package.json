{
  "name": "shellx",
  "version": "1.0.0",
  "description": "A modern CLI chatbot with minimal interface",
  "main": "dist/index.js",
  "bin": {
    "shellx": "./bin/shellx.js",
    "shx": "./bin/shellx.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --platform=node --outfile=dist/index.js --external:inquirer --external:commander --external:ora --external:chalk --external:winston",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "chatbot",
    "terminal",
    "command-line"
  ],
  "author": "Akshit Sinha",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/ai-utils": "^1.0.1",
    "@inquirer/prompts": "^7.8.6",
    "agents": "^0.2.10",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "inquirer": "^12.9.6",
    "ora": "^9.0.0",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251008.0",
    "@types/node": "^22.18.9",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3",
    "wrangler": "^4.42.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
