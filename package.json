{
  "name": "ai-shellx",
  "version": "0.0.1",
  "description": "A shell command assistant - get help with terminal commands and shell operations",
  "main": "dist/index.js",
  "bin": {
    "shellx": "./bin/shellx.js",
    "shx": "./bin/shellx.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --platform=node --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "clean": "rm -rf dist",
    "deploy": "wrangler deploy",
    "worker:dev": "wrangler dev",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "chatbot",
    "terminal",
    "command-line"
  ],
  "author": "Akshit Sinha",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.9.0",
    "agents": "^0.2.13",
    "ai": "^5.0.70",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "ora": "^9.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "workers-ai-provider": "^2.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.18.10",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3",
    "wrangler": "^4.42.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
