{
  "name": "shxai",
  "version": "0.2.3",
  "description": "shxai: AI-powered shell command assistant for the terminal. Natural language to shell commands, with interactive refinement.",
  "main": "dist/index.js",
  "bin": {
    "shxai": "bin/shxai.js",
    "shx": "bin/shxai.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --platform=node --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "dev": "npm run build && cross-env NODE_ENV=development node dist/index.js",
    "clean": "rm -rf dist",
    "deploy": "wrangler deploy",
    "worker:dev": "wrangler dev",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "format": "prettier --write 'src/**/*.{ts,js}'"
  },
  "keywords": [
    "ai",
    "cli",
    "terminal",
    "command-line"
  ],
  "author": "Akshit Sinha",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "agents": "^0.3.6",
    "ai": "^6.0.48",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "ora": "^9.1.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "workers-ai-provider": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.9",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3",
    "wrangler": "^4.60.0"
  },
  "lint-staged": {
    "*.ts": "prettier --write",
    "*.js": "prettier --write"
  },
  "engines": {
    "node": ">=22"
  }
}
